# Скопируйте в .env или задайте переменные вручную.
# Docker Compose читает .env из каталога проекта (см. start.ps1 -Action compose-up).

# Явное имя проекта Compose — не зависит от имени родительской папки на диске.
COMPOSE_PROJECT_NAME=egisz-monitor-corp

POSTGRES_DB=egisz_reports
POSTGRES_USER=egisz
POSTGRES_PASSWORD=egisz

# Порт PostgreSQL на хосте Windows (в контейнере всегда 5432).
# 5433 по умолчанию, чтобы не пересекаться с другим Postgres на хосте (часто 5432).
CORP_DB_PORT=5433

# Переменные EGISZ_CORP_POSTGRES_* (если задать) перекрывают секцию postgres в egisz_corp.yaml
# при запуске CLI/веба — см. egisz_monitor_corp/config_loader.py.
