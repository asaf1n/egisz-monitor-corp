# Скопируйте в .env (start.ps1 делает это при первом deploy) или задайте переменные вручную.
# Docker Compose подставляет их в docker-compose.yml.

POSTGRES_DB=egisz_corp
POSTGRES_USER=egisz_corp
POSTGRES_PASSWORD=egisz_corp

# Порт PostgreSQL на хосте Windows (в контейнере всегда 5432).
# 5433 по умолчанию, чтобы не пересекаться с основным стеком egisz-monitor на 5432.
CORP_DB_PORT=5433

# start.ps1 подставляет CORP_DB_PORT и POSTGRES_* в переменные EGISZ_CORP_POSTGRES_*,
# которые перекрывают секцию postgres в egisz_corp.yaml (см. config_loader.py).
