# Уменьшаем build context для docker/web/Dockerfile и metabase/Dockerfile.
# Файлы конфига (k8s/egisz_monitor.local.yaml, *.example.yaml) и SQL остаются — Dockerfile их COPY-ит явно.
.git/
.github/
.gitignore
.gitattributes
.cursor/
.cursorrules

# Виртуальные окружения и кеши Python.
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Тесты не нужны в runtime образе (gunicorn их не запускает).
tests/

# IDE / редакторы.
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Артефакты сборки.
build/
dist/
*.egg-info/
*.egg

# Локальные секреты / стейт start.ps1.
.egisz-monitor-port-forward.pids
k8s/egisz_monitor.local.yaml
k8s/postgres/postgres-credentials.yaml
k8s/metabase-admin-secret.yaml
.sync-err.log
.sync-out.log
debug-*.log

# Большие/неиспользуемые ресурсы Metabase (для образа conf-ui они не нужны;
# metabase/Dockerfile сам их COPY-ит из metabase_dashboards/).
metabase_dashboards/.manifest.sha256

# Документация и переписки агента.
docs/
*.md
!README.md
AGENTS.md
agent-transcripts/
terminals/

# Временные файлы Windows.
Thumbs.db
desktop.ini

# Временные файлы и резервные копии k8s.
.k8s-backups/

# Конфиги редакторов/IDE специфичные для проекта (не нужны в контейнере).
.editorconfig
.prettierrc
.eslintrc

# Автозаполненные пароли/сессии.
.env.local
.env.*.local
