{
  "name": "Оперативный мониторинг",
  "description": "Сводные статусы за последние 24 ч и лента до 50 последних операций в окне 24 ч (по дате обработки). Детальные списки ошибок СЭМД — дашборд «Ошибки и разбор».",
  "parameters": [],
  "cards": [
    {
      "name": "Сводно за 24 ч",
      "description": "Агрегат по витрине за интервал 24 ч от текущего момента (поле «Обработано»).",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COUNT(*)::bigint AS \"Всего\", SUM(CASE WHEN \"Статус\" = 'success' THEN 1 ELSE 0 END)::bigint AS \"Успех\", SUM(CASE WHEN \"Статус\" = 'error' THEN 1 ELSE 0 END)::bigint AS \"Ошибка\", SUM(CASE WHEN \"Статус\" = 'unknown' OR \"Статус\" IS NULL THEN 1 ELSE 0 END)::bigint AS \"Неизвестно\" FROM public.v_egisz_transactions_enriched_ui WHERE \"Обработано\" >= NOW() - INTERVAL '24 hours'",
          "template-tags": {}
        },
        "database": 1
      },
      "display": "table",
      "visualization_settings": {
        "column_settings": {
          "[\"name\",\"Всего\"]": { "column_title": "Всего", "number_separators": ".", "decimals": 0 },
          "[\"name\",\"Успех\"]": { "column_title": "Успех", "number_separators": ".", "decimals": 0 },
          "[\"name\",\"Ошибка\"]": { "column_title": "Ошибка", "number_separators": ".", "decimals": 0 },
          "[\"name\",\"Неизвестно\"]": { "column_title": "Неизвестно", "number_separators": ".", "decimals": 0 }
        }
      },
      "sizeX": 24,
      "sizeY": 4,
      "row": 0,
      "col": 0
    },
    {
      "name": "Топ типов СЭМД",
      "description": "Количество записей по kind_code.",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), '(пусто)') AS \"Код СЭМД\", COALESCE(NULLIF(TRIM(\"Наименование СЭМД\"), ''), '(пусто)') AS \"Наименование СЭМД\", COUNT(*)::bigint AS \"Количество\" FROM public.v_egisz_transactions_enriched_ui GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 25",
          "template-tags": {}
        },
        "database": 1
      },
      "display": "bar",
      "visualization_settings": {
        "graph.dimensions": ["Наименование СЭМД"],
        "graph.metrics": ["Количество"],
        "graph.x_axis.axis_enabled": "rotate-45",
        "column_settings": {
          "[\"name\",\"Код СЭМД\"]": { "column_title": "Код СЭМД" },
          "[\"name\",\"Наименование СЭМД\"]": { "column_title": "Наименование СЭМД" },
          "[\"name\",\"Количество\"]": { "column_title": "Количество", "number_separators": ".", "decimals": 0 }
        }
      },
      "sizeX": 12,
      "sizeY": 6,
      "row": 4,
      "col": 0
    },
    {
      "name": "По клиникам (имя)",
      "description": "Топ клиник по числу записей.",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT \"JID клиники\", \"Наименование клиники\", COUNT(*)::bigint AS \"Количество\" FROM public.v_egisz_transactions_enriched_ui GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 20",
          "template-tags": {}
        },
        "database": 1
      },
      "display": "row",
      "visualization_settings": {
        "graph.dimensions": ["Наименование клиники"],
        "graph.metrics": ["Количество"],
        "column_settings": {
          "[\"name\",\"JID клиники\"]": { "column_title": "JID клиники" },
          "[\"name\",\"Наименование клиники\"]": { "column_title": "Наименование клиники" },
          "[\"name\",\"Количество\"]": { "column_title": "Количество", "number_separators": ".", "decimals": 0 }
        }
      },
      "sizeX": 12,
      "sizeY": 6,
      "row": 4,
      "col": 12
    },
    {
      "name": "Статусы за 24 ч",
      "description": "Успех / ошибка / неизвестно в окне 24 ч.",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT \"Статус\", COUNT(*)::bigint AS \"Количество\" FROM public.v_egisz_transactions_enriched_ui WHERE \"Обработано\" >= NOW() - INTERVAL '24 hours' GROUP BY 1 ORDER BY 2 DESC",
          "template-tags": {}
        },
        "database": 1
      },
      "display": "pie",
      "visualization_settings": {
        "pie.show_legend": true,
        "pie.dimension": ["Статус"],
        "pie.metric": ["Количество"],
        "column_settings": {
          "[\"name\",\"Статус\"]": { "column_title": "Статус" },
          "[\"name\",\"Количество\"]": { "column_title": "Количество", "number_separators": ".", "decimals": 0 }
        }
      },
      "sizeX": 8,
      "sizeY": 6,
      "row": 10,
      "col": 0
    },
    {
      "name": "Последние операции",
      "description": "До 50 последних строк за 24 ч (по дате обработки, новые сверху).",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT * FROM public.v_egisz_transactions_enriched_ui WHERE \"Обработано\" >= NOW() - INTERVAL '24 hours' ORDER BY \"Обработано\" DESC NULLS LAST LIMIT 50",
          "template-tags": {}
        },
        "database": 1
      },
      "display": "table",
      "visualization_settings": {
        "column_settings": {
          "[\"name\",\"Связанное сообщение\"]": { "column_title": "Связанное сообщение (relatesToMessage)" },
          "[\"name\",\"localUid СЭМД\"]": { "column_title": "localUid СЭМД" },
          "[\"name\",\"JID клиники\"]": { "column_title": "JID клиники" },
          "[\"name\",\"Токен gost-хоста\"]": { "column_title": "Токен gost-хоста" },
          "[\"name\",\"OID организации\"]": { "column_title": "OID организации" },
          "[\"name\",\"Код СЭМД\"]": { "column_title": "Код СЭМД" },
          "[\"name\",\"Наименование СЭМД\"]": { "column_title": "Наименование СЭМД" },
          "[\"name\",\"Статус\"]": { "column_title": "Статус" },
          "[\"name\",\"EMDR ID\"]": { "column_title": "EMDR ID" },
          "[\"name\",\"Ошибки JSON\"]": { "column_title": "Ошибки JSON" },
          "[\"name\",\"Дата регистрации\"]": { "column_title": "Дата регистрации" },
          "[\"name\",\"Обработано\"]": { "column_title": "Обработано" },
          "[\"name\",\"Наименование клиники\"]": { "column_title": "Наименование клиники" },
          "[\"name\",\"ИНН клиники\"]": { "column_title": "ИНН клиники" },
          "[\"name\",\"OID клиники\"]": { "column_title": "OID клиники" }
        }
      },
      "sizeX": 16,
      "sizeY": 8,
      "row": 10,
      "col": 8
    }
  ]
}
