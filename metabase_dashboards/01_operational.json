  "cards": [
    {
      "name": "Сводно за период",
      "description": "Агрегат по витрине за выбранный период (поле «Обработано»).",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH vit_ref AS ( SELECT COALESCE((SELECT MAX(\"Обработано\") FROM public.v_egisz_transactions_enriched_ui), NOW()) AS ref_ts ) SELECT COUNT(*)::bigint AS \"Всего\", SUM(CASE WHEN \"Статус\" = 'success' THEN 1 ELSE 0 END)::bigint AS \"Успех\", SUM(CASE WHEN \"Статус\" = 'error' THEN 1 ELSE 0 END)::bigint AS \"Ошибка\", SUM(CASE WHEN \"Статус\" = 'unknown' OR \"Статус\" IS NULL THEN 1 ELSE 0 END)::bigint AS \"Неизвестно\" FROM public.v_egisz_transactions_enriched_ui CROSS JOIN vit_ref WHERE \"Обработано\" >= vit_ref.ref_ts - (interval '1 day' * GREATEST(1, ({{op_period}}::numeric))) [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{op_semd}}]] [[AND \"JID клиники\"::text = {{op_clinic}}]]",
          "template-tags": {
            "op_period": {
              "id": "f1000001-0001-4001-8001-000000000001",
              "name": "op_period",
              "display-name": "Период (обработано) (глубина, дней)",
              "type": "number",
              "required": true,
              "default": 30
            },
            "op_semd": {
              "id": "f1000001-0001-4001-8001-000000000010",
              "name": "op_semd",
              "display-name": "Код СЭМД",
              "type": "text",
              "widget-type": "string/=",
              "required": false
            },
            "op_clinic": {
              "id": "f1000001-0001-4001-8001-000000000011",
              "name": "op_clinic",
              "display-name": "JID клиники",
              "type": "text",
              "widget-type": "string/=",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "table",
      "visualization_settings": {
        "column_settings": {
          "[\"name\",\"Всего\"]": {
            "column_title": "Всего",
            "number_separators": ".",
            "decimals": 0
          },
          "[\"name\",\"Успех\"]": {
            "column_title": "Успех",
            "number_separators": ".",
            "decimals": 0
          },
          "[\"name\",\"Ошибка\"]": {
            "column_title": "Ошибка",
            "number_separators": ".",
            "decimals": 0
          },
          "[\"name\",\"Неизвестно\"]": {
            "column_title": "Неизвестно",
            "number_separators": ".",
            "decimals": 0
          }
        }
      },
      "sizeX": 24,
      "sizeY": 4,
      "row": 0,
      "col": 0
    },
