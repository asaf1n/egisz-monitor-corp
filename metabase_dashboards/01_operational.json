    {
      "name": "Доля ошибок по СЭМД",
      "description": "Топ-10 типов СЭМД среди error (код; при пустом коде — наименование; иначе «неизвестно»); хвост — «Остальные (N)». «Итого» = все error за период.",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH per_code AS ( SELECT LEFT( CASE WHEN NULLIF(TRIM(\"Код СЭМД\"), '') IS NOT NULL THEN TRIM(\"Код СЭМД\") || COALESCE(' · ' || NULLIF(LEFT(TRIM(\"Наименование СЭМД\"), 32), ''), '') WHEN NULLIF(TRIM(\"Наименование СЭМД\"), '') IS NOT NULL THEN LEFT(TRIM(\"Наименование СЭМД\"), 72) ELSE '(неизвестно)' END, 80 ) AS lbl, COUNT(DISTINCT \"Связанное сообщение\")::bigint AS cnt FROM public.v_egisz_transactions_enriched_ui WHERE \"Статус\" = 'error' AND 1=1 [[AND {{dwh_date}}]] [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{top_semd}}]] [[AND \"JID клиники\"::text = {{top_clinic}}]] GROUP BY 1 ), ranked AS ( SELECT lbl, cnt, ROW_NUMBER() OVER (ORDER BY cnt DESC) AS rn FROM per_code ), tail AS ( SELECT COALESCE(SUM(cnt), 0)::bigint AS tail_cnt FROM ranked WHERE rn > 10 ) SELECT CASE WHEN r.rn <= 10 THEN r.lbl ELSE 'Остальные (' || t.tail_cnt::text || ')' END AS \"СЭМД\", SUM(r.cnt)::bigint AS \"Количество\" FROM ranked r CROSS JOIN tail t GROUP BY CASE WHEN r.rn <= 10 THEN r.lbl ELSE 'Остальные (' || t.tail_cnt::text || ')' END ORDER BY 2 DESC",
          "template-tags": {
            "top_semd": {
              "type": "text",
              "widget-type": "string/=",
              "id": "fa000003-0003-4003-8003-000000000010",
              "name": "top_semd",
              "display-name": "Код СЭМД",
              "required": false
            },
            "dwh_date": {
              "type": "dimension",
              "widget-type": "date/all-options",
              "id": "fa000003-0003-4003-8003-000000000001",
              "name": "dwh_date",
              "display-name": "По дате «Обработано»"
            },
            "top_clinic": {
              "type": "text",
              "widget-type": "string/=",
              "id": "fa000003-0003-4003-8003-000000000011",
              "name": "top_clinic",
              "display-name": "JID клиники",
              "required": false
            }
          }
        },
        "database": 1
      },
