    {
      "name": "Доля топ-ошибок (ЕГИСЗ)",
      "description": "До 8 наиболее частых формулировок по первому элементу «Ошибки JSON» на транзакцию; хвост — «Остальные (N)», N = число транзакций вне топ‑8. «Итого» = все error за период (как «Статусы за период»).",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH per_err AS ( SELECT COALESCE( ( SELECT LEFT(public.egisz_friendly_error_item(err->>'code', err->>'message'), 52) FROM jsonb_array_elements(COALESCE(env.\"Ошибки JSON\", '[]'::jsonb)) AS e(err) WHERE NULLIF(err->>'message', '') IS NOT NULL OR NULLIF(err->>'code', '') IS NOT NULL LIMIT 1 ), '(ошибка без деталей)' ) AS err_lbl, COUNT(*)::bigint AS cnt FROM public.v_egisz_transactions_enriched_ui env WHERE env.\"Статус\" = 'error' AND 1=1 [[AND {{dwh_date}}]] GROUP BY 1 ), ranked AS ( SELECT err_lbl, cnt, ROW_NUMBER() OVER (ORDER BY cnt DESC) AS rn FROM per_err ), tail AS ( SELECT COALESCE(SUM(cnt), 0)::bigint AS tail_cnt FROM ranked WHERE rn > 8 ) SELECT CASE WHEN r.rn <= 8 THEN r.err_lbl ELSE 'Остальные (' || t.tail_cnt::text || ')' END AS \"Тип ошибки\", SUM(r.cnt)::bigint AS \"Количество\" FROM ranked r CROSS JOIN tail t GROUP BY CASE WHEN r.rn <= 8 THEN r.err_lbl ELSE 'Остальные (' || t.tail_cnt::text || ')' END ORDER BY 2 DESC",
          "template-tags": {
            "dwh_date": {
              "widget-type": "date/all-options",
              "id": "fa000002-0002-4002-8002-000000000001",
              "name": "dwh_date",
              "display-name": "По дате «Обработано»",
              "type": "dimension"
            }
          }
        },
        "database": 1
      },
