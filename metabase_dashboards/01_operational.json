          "query": "WITH filtered AS ( SELECT v.* FROM public.v_egisz_transactions_enriched_ui v WHERE 1=1 [[AND {{dwh_date}}]] ), with_err AS ( SELECT f.*, CASE WHEN f.\"Статус\" = 'success' THEN '(успешно)' WHEN f.\"Статус\" = 'unknown' THEN '(неизвестно)' WHEN f.\"Статус\" = 'error' THEN COALESCE( ( SELECT LEFT(public.egisz_friendly_error_item(err->>'code', err->>'message'), 120) FROM jsonb_array_elements(COALESCE(f.\"Ошибки JSON\", '[]'::jsonb)) AS e(err) WHERE NULLIF(err->>'message', '') IS NOT NULL OR NULLIF(err->>'code', '') IS NOT NULL LIMIT 1 ), '(ошибка без деталей)' ) ELSE '(' || COALESCE(f.\"Статус\", '?') || ')' END AS err_kind FROM filtered f ) SELECT COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), '(пусто)') AS \"Тип СЭМД\", \"JID клиники\", COALESCE(NULLIF(TRIM(\"Наименование клиники\"), ''), '(нет)') AS \"Наименование клиники\", err_kind AS \"Тип ошибки\", COUNT(*)::bigint AS \"Транзакций\", SUM(CASE WHEN \"Статус\" = 'error' THEN 1 ELSE 0 END)::bigint AS \"Ошибок\", ROUND(100.0 * SUM(CASE WHEN \"Статус\" = 'error' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS \"Процент ошибок\" FROM with_err GROUP BY 1, 2, 3, 4 ORDER BY \"Ошибок\" DESC, \"Транзакций\" DESC LIMIT 500",
