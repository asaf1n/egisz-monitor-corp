              "widget-type": "string/=",
              "id": "fa000002-0002-4002-8002-000000000011",
              "name": "top_clinic",
              "display-name": "JID клиники",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "pie",
      "visualization_settings": {
