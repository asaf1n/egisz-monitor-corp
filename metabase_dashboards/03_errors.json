    {
      "name": "03 · Ошибки парсинга (stg_parse_errors)",
      "description": "Последние 100 записей staging; field filter по **created_at**.",
      "table_ref": "stg_parse_errors",
      "metabase-field-filters": { "dwh_date": { "table_ref": "stg_parse_errors", "field_name": "created_at" } },
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT id AS \"Номер записи\", error_code AS \"Код ошибки\", LEFT(message, 200) AS \"Сообщение\", created_at AS \"Создано\", relates_to_id AS \"Связанное сообщение\" FROM public.stg_parse_errors WHERE 1=1 [[AND {{dwh_date}}]] [[AND error_code::text = {{err_parse_code}}]] ORDER BY id DESC LIMIT 100",
          "template-tags": {
            "dwh_date": {
              "id": "f3000001-0001-4001-8001-000000000001",
              "name": "dwh_date",
              "display-name": "По дате created_at (stg)",
              "type": "dimension",
              "widget-type": "date/all-options"
            },
            "err_parse_code": {
              "id": "f3000001-0001-4001-8001-000000000010",
              "name": "err_parse_code",
              "display-name": "Код ошибки парсинга",
              "type": "text",
              "widget-type": "string/=",
              "required": false
            }
          }
        },
        "database": 1
      },
