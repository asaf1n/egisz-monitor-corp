    {
      "name": "Ошибки по типу (код ЕГИСЗ)",
      "description": "Распределение ошибочных транзакций по коду из ответа ЕГИСЗ (ns2:code в JSON); если кода нет — по началу текста сообщения. Тот же период (дата обработки), что у KPI выше.",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT (\n  CASE\n    WHEN NULLIF(TRIM(err->>'code'), '') IS NOT NULL THEN TRIM(err->>'code')\n    ELSE LEFT(COALESCE(NULLIF(TRIM(err->>'message'), ''), '(нет текста)'), 120)\n  END\n) AS \"Тип ошибки\",\nCOUNT(*)::bigint AS \"Количество\"\nFROM public.v_egisz_transactions_enriched_ui,\njsonb_array_elements(\"Ошибки JSON\") AS e(err)\nWHERE {{period}} AND \"Статус\" = 'error'\n  AND (NULLIF(err->>'message', '') IS NOT NULL OR NULLIF(err->>'code', '') IS NOT NULL)\nGROUP BY 1\nORDER BY 2 DESC\nLIMIT 20",
          "template-tags": {
            "period": {
              "id": "b1c2d3e4-f5a6-7890-bcde-f12345678904",
              "name": "period",
              "display-name": "Период (дата обработки)",
              "type": "dimension",
              "widget-type": "date/all-options"
            }
          }
