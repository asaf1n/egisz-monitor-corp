      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT ROUND(SUM(CASE WHEN \"Статус\"='error' THEN 1 ELSE 0 END)*100.0 / NULLIF(COUNT(*), 0), 2) AS \"Процент ошибок\" FROM public.v_egisz_transactions_enriched_ui WHERE {{period}}",
