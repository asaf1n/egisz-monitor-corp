  "cards": [
    {
      "name": "Топ типов СЭМД",
      "description": "Количество записей по коду и наименованию СЭМД.",
      "table_ref": "v_egisz_transactions_enriched_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(\"Код СЭМД\"), ''), '(пусто)') AS \"Код СЭМД\", COALESCE(NULLIF(TRIM(\"Наименование СЭМД\"), ''), '(пусто)') AS \"Наименование СЭМД\", COUNT(*)::bigint AS \"Количество\" FROM public.v_egisz_transactions_enriched_ui CROSS JOIN ( SELECT COALESCE((SELECT MAX(\"Обработано\") FROM public.v_egisz_transactions_enriched_ui), NOW()) AS ref_ts ) vit_ref WHERE \"Обработано\" >= vit_ref.ref_ts - (interval '1 day' * GREATEST(1, ({{srv_period}}::numeric))) [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{srv_semd}}]] [[AND \"JID клиники\"::text = {{srv_clinic}}]] GROUP BY 1, 2 ORDER BY 3 DESC LIMIT 25",
          "template-tags": {
            "srv_period": {
              "id": "f2000001-0001-4001-8001-000000000001",
              "name": "srv_period",
              "display-name": "Период (обработано) (глубина, дней)",
              "type": "number",
              "required": true,
              "default": 30
            },
            "srv_semd": {
              "id": "f2000001-0001-4001-8001-000000000010",
