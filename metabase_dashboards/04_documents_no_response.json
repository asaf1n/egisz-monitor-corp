{
  "name": "04 Документы без ответа",
  "description": "Поиск «зависших» транзакций. Анализ документов, по которым не поступил подтверждающий callback от ЕГИСЗ. Фильтр по дате отправки.",
  "parameters": [
    {
      "id": "d4c3b2a1-0f9e-4789-8012-3456789abcde",
      "name": "Период (отправлено) — глубина, дней",
      "slug": "sent_period_filter",
      "type": "number/=",
      "sectionId": "number",
      "default": 30
    }
  ],
  "cards": [
    {
      "name": "Документы без ответа",
      "description": "Строки v_rpt_documents_no_response_ui (подписи из dim_column_display_labels).",
      "table_ref": "v_rpt_documents_no_response_ui",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH pend_ref AS ( SELECT COALESCE((SELECT MAX(\"Отправлено\") FROM public.v_rpt_documents_no_response_ui), NOW()) AS ref_ts ) SELECT v.* FROM public.v_rpt_documents_no_response_ui v CROSS JOIN pend_ref WHERE v.\"Отправлено\" >= pend_ref.ref_ts - (interval '1 day' * GREATEST(1, ({{sent_period}}::numeric))) ORDER BY v.\"Отправлено\" DESC NULLS LAST LIMIT 100",
          "template-tags": {
            "sent_period": {
              "id": "f4000001-0001-4001-8001-000000000001",
              "name": "sent_period",
              "display-name": "Период (отправлено) (глубина, дней)",
              "type": "number",
              "required": true,
              "default": 30
            }
          }
        },
        "database": 1
      },
      "display": "table",
      "visualization_settings": {
        "column_settings": {
          "[\"name\",\"localUid СЭМД\"]": {
            "column_title": "localUid СЭМД"
          },
          "[\"name\",\"Код СЭМД\"]": {
            "column_title": "Код СЭМД"
          },
          "[\"name\",\"Наименование СЭМД\"]": {
            "column_title": "Наименование СЭМД"
          },
          "[\"name\",\"JID клиники\"]": {
            "column_title": "JID клиники"
          },
          "[\"name\",\"Наименование клиники\"]": {
            "column_title": "Наименование клиники"
          },
          "[\"name\",\"Хост клиники (VPN ГОСТ)\"]": {
            "column_title": "Хост клиники (VPN ГОСТ)"
          },
          "[\"name\",\"Отправлено\"]": {
            "column_title": "Отправлено"
          }
        }
      },
      "sizeX": 24,
      "sizeY": 10,
      "row": 0,
      "col": 0
    }
  ]
}
