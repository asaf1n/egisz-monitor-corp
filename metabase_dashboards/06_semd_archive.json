    {
      "name": "06 · Документы по типам СЭМД",
      "description": "Ось X — тип СЭМД (код и краткое наименование), ось Y — число уникальных документов.",
      "table_ref": "v_rpt_semd_archive_ui",
      "metabase-field-filters": {
        "dwh_date": {
          "table_ref": "v_rpt_semd_archive_ui",
          "field_name": "Дата обработки"
        }
      },
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT LEFT(CASE WHEN NULLIF(TRIM(\"Код СЭМД\"), '') IS NOT NULL THEN TRIM(\"Код СЭМД\") || COALESCE(' · ' || NULLIF(LEFT(TRIM(\"Наименование СЭМД\"), 28), ''), '') WHEN NULLIF(TRIM(\"Наименование СЭМД\"), '') IS NOT NULL THEN LEFT(TRIM(\"Наименование СЭМД\"), 64) ELSE '(неизвестно)' END, 72) AS \"Тип СЭМД\", COUNT(DISTINCT \"Связанное сообщение\")::bigint AS \"Документов\" FROM public.v_rpt_semd_archive_ui WHERE 1=1 [[AND {{dwh_date}}]] [[AND NULLIF(TRIM(\"Код СЭМД\"), '') = {{top_semd}}]] [[AND \"JID\"::text = {{top_clinic}}]] GROUP BY 1 ORDER BY 2 DESC NULLS LAST LIMIT 40",
          "template-tags": {
            "dwh_date": {
              "id": "f0900003-3003-4003-8003-000000000001",
              "name": "dwh_date",
              "display-name": "По дате «Дата обработки»",
              "type": "dimension",
              "widget-type": "date/all-options"
            },
            "top_semd": {
              "id": "f0900003-3003-4003-8003-000000000010",
              "name": "top_semd",
              "display-name": "Код СЭМД",
              "type": "text",
              "widget-type": "string/=",
              "required": false
            },
            "top_clinic": {
              "id": "f0900003-3003-4003-8003-000000000011",
              "name": "top_clinic",
              "display-name": "JID клиники",
              "type": "text",
              "widget-type": "string/=",
              "required": false
            }
          }
        },
        "database": 1
      },
