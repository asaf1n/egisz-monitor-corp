table ReadmePlaceholder

	partition ReadmePlaceholder = m
		mode: import
		source =
				let
				    Source = #table( type table [Hint = text], {{"Подключите PostgreSQL (см. README). SQL: sql/*.sql"}})
				in
				    Source

	column Hint
		dataType: string
		lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890
		summarizeBy: none
		sourceColumn: Hint
